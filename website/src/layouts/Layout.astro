---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentPage?: 'home' | 'plugins' | 'skills';
}

const {
  title = 'Daniel (DSR) Scott-Raynsford Plugin Marketplace',
  description = 'Daniel (DSR) Scott-Raynsford\'s plugin marketplace — curated skills for GitHub Copilot and coding agents.',
  currentPage = 'home',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>

    <header class="site-header">
      <div class="container site-header__inner">
        <a href={base} class="site-header__brand">
          <span class="gradient-text">DSR</span>
          <span class="site-header__brand-suffix">&nbsp;Plugin Marketplace</span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a
            href={base}
            class:list={['site-nav__link', { 'is-active': currentPage === 'home' }]}
          >Home</a>
          <a
            href={`${base}plugins/`}
            class:list={['site-nav__link', { 'is-active': currentPage === 'plugins' }]}
          >Plugins</a>
          <a
            href={`${base}skills/`}
            class:list={['site-nav__link', { 'is-active': currentPage === 'skills' }]}
          >Skills</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container">
        <p>
          Made with <span aria-label="love" role="img">&#x1F49C;</span> by
          <a href="https://danielscottraynsford.com">Daniel Scott-Raynsford</a>
        </p>
        <nav class="site-footer__links" aria-label="Footer links">
          <a href="https://github.com/PlagueHO/plagueho.skills">GitHub</a>
          <a href="https://agentskills.io">Agent Skills Spec</a>
          <a href="https://github.com/github/awesome-copilot">Awesome Copilot</a>
        </nav>
      </div>
    </footer>

  </body>
</html>
